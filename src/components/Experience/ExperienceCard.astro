---
interface Props {
  company: string;

  title: string;

  duration: string;

  highlights: string[];

  stack: string[];
}

const {
  company,

  title,

  duration,

  highlights,

  stack,
} = Astro.props;
---

<div class="card">
  <div class="card-title">
    <h3>{company}</h3>

    <span>{duration}</span>
  </div>

  <p class="card-subtitle">
    {title}
  </p>

  <ul>
    {highlights.map((item) => <li>{item}</li>)}
  </ul>

  <div class="tech-stack">
    {stack.map((tech) => <span>{tech}</span>)}
  </div>
</div>
