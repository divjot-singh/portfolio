---
import { projects } from "../../data/projects";
import SectionHeading from "../Common/SectionHeading.astro";
import ProjectCard from "./ProjectCard.astro";
import ProjectListItem from "./ProjectListItem.astro";

const { printable = false } = Astro.props;
---

<section id="projects" class="section">
  <SectionHeading title="Selected Work" />

  <p class="section-subtitle">
    A selection of enterprise platforms, AI products, and software systems I've
    designed and delivered across Microsoft, Tredence, GreyOrange, Game.tv and
    Mindfusion Studios.
  </p>

  {
    printable ? (
      <div class="project-list">
        {projects.map((project) => (
          <ProjectListItem project={project} />
        ))}
      </div>
    ) : (
      <div class="project-grid">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )
  }
</section>
