---
import Layout from "../../layouts/Layout.astro";
import Chip from "../../components/Common/Chip.astro";
import { projects } from "../../data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Divjot Singh`}>
  <section class="case-study">
    <a href="/#projects" class="back-link"> ← Back to Projects </a>

    <div class="case-hero">
      <div class="case-header">
        <span class="case-category" style={`color:${project.accent}`}>
          {project.category}
        </span>

        <h1>{project.title}</h1>

        <p class="case-subtitle">
          {project.subtitle}
        </p>
      </div>

      <div class="case-meta">
        <div>
          <span>Company</span>
          <strong>{project.company}</strong>
        </div>

        <div>
          <span>Role</span>
          <strong>{project.role}</strong>
        </div>

        <div>
          <span>Duration</span>
          <strong>{project.duration}</strong>
        </div>

        <div>
          <span>Team</span>
          <strong>{project.team}</strong>
        </div>
      </div>

      {
        project.image && (
          <img src={project.image} alt={project.title} class="hero-image" />
        )
      }
    </div>

    <section class="case-section">
      <h2>Overview</h2>

      <p>
        {project.description}
      </p>
    </section>

    <section class="case-section">
      <h2>Engineering Challenge</h2>

      <p>
        {project.challenge}
      </p>
    </section>

    <section class="case-section">
      <h2>My Contributions</h2>

      <ul class="contribution-list">
        {project.contributions.map((item: string) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="case-section">
      <h2>Technology Stack</h2>

      <div class="project-stack">
        {project.stack.map((tech: string) => <Chip label={tech} />)}
      </div>
    </section>

    {
      project.metrics && (
        <section class="case-section">
          <h2>Project Highlights</h2>

          <div class="metrics">
            {project.metrics.map((metric: any) => (
              <div class="metric-card">
                <h3>{metric.value}</h3>

                <p>{metric.label}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      project.website && (
        <section class="case-section">
          <a href={project.website} target="_blank" class="visit-product">
            Visit Live Product ↗
          </a>
        </section>
      )
    }
  </section>
</Layout>
